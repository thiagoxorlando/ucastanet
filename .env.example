# App URL
# Set this to your real public domain in production.
# The code falls back to http://localhost:3000 in some routes, but that is not safe for production emails or webhook callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
# Required for local development and production.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Mercado Pago
# Required for payment flows.
# Use test credentials locally and live credentials in production.
MERCADO_PAGO_ACCESS_TOKEN=YOUR_MERCADO_PAGO_ACCESS_TOKEN

# Required for card tokenization and card-related UI flows.
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=YOUR_MERCADO_PAGO_PUBLIC_KEY

# Strongly recommended in production.
# Leave blank only if you intentionally want to skip webhook signature validation in local development.
MERCADO_PAGO_WEBHOOK_SECRET=YOUR_MERCADO_PAGO_WEBHOOK_SECRET

# Email (Resend)
# Required for referral invites, resend-email flows, and the admin email test route.
# Never prefix this with NEXT_PUBLIC_.
RESEND_API_KEY=

# Required in production. This sender/domain must be verified in Resend.
# Local development falls back to BrisaHub <noreply@brisahub.com.br> only if this is blank.
RESEND_FROM_EMAIL=BrisaHub <noreply@brisahub.com.br>

# Stripe
# STRIPE_SECRET_KEY must NEVER be prefixed with NEXT_PUBLIC_ — keep it server-only.
# Use sk_test_* locally and sk_live_* in production.
STRIPE_SECRET_KEY=
# Webhook signing secret — obtain from Stripe Dashboard > Webhooks > signing secret.
# Required in production; leave blank to skip signature validation locally.
STRIPE_WEBHOOK_SECRET=
# Publishable key — safe to expose client-side (checkout flows, Elements).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App URL (override if not already set above — used for webhook callbacks)
# NEXT_PUBLIC_APP_URL=https://brisahub.com.br

# Tooling
# Optional. Only used by scripts/github-setup.mjs, not by the deployed app.
GITHUB_TOKEN=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN
