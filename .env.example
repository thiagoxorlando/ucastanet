# ── App ───────────────────────────────────────────────────────────────────────
# Set this to your real public domain in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for local development and production.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Asaas (active payment provider) ──────────────────────────────────────────
# Required for plan subscriptions, wallet deposits, and withdrawals.
# Use sandbox credentials locally, production credentials in production.
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=YOUR_ASAAS_API_KEY
# Webhook token — must match the token configured in Asaas dashboard.
# Required in production; leave blank to skip signature validation locally.
ASAAS_WEBHOOK_TOKEN=YOUR_ASAAS_WEBHOOK_TOKEN

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Required for referral invites, notification emails, and the admin email test route.
# Never prefix this with NEXT_PUBLIC_.
RESEND_API_KEY=
# Required in production. This sender/domain must be verified in Resend.
RESEND_FROM_EMAIL=BrisaHub <noreply@brisahub.com.br>

# ── Tooling ───────────────────────────────────────────────────────────────────
# Optional. Only used by scripts/github-setup.mjs, not by the deployed app.
GITHUB_TOKEN=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN

# ── Legacy / Disabled ─────────────────────────────────────────────────────────
# The following providers are no longer active. Do not add new code that
# references these. Routes that used them now return 410 Gone.

# Stripe (disabled — replaced by Asaas)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Mercado Pago (disabled)
# MERCADO_PAGO_ACCESS_TOKEN=
# NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=
# MERCADO_PAGO_WEBHOOK_SECRET=

# Efí / Gerencianet (disabled)
# EFI_CLIENT_ID=
# EFI_CLIENT_SECRET=
# EFI_PIX_KEY=
